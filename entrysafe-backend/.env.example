# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=entrysafe_production

# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=./firebase-admin.json

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False

# CORS Origins
CORS_ORIGINS=https://yourdomain.com

# Environment
ENVIRONMENT=production

# OpenAI API Keys (one per app for usage tracking)
OPENAI_KEY_ACCOUNTING=sk-your-accounting-key-here
OPENAI_KEY_DOCS=sk-your-docs-key-here
OPENAI_KEY_PRICING=sk-your-pricing-key-here
OPENAI_KEY_SD_STORAGE_HELPER=sk-your-sdstorage-key-here
